// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum HabitFrequency {
  DAILY
  WEEKLY
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  expenses     Expense[]
  habits       Habit[]
  checkIns     HabitCheckIn[]
  categories   Category[]
}

model Expense {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  amountCents Int
  currency   String   @default("EUR")
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  occurredAt DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, occurredAt])
  @@index([userId, categoryId])
}

model Habit {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  frequency   HabitFrequency @default(DAILY)
  targetCount Int           @default(1)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  checkIns    HabitCheckIn[]

  @@index([userId, isActive])
  @@index([userId, frequency])
}

model HabitCheckIn {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  day       DateTime // normalized to UTC midnight
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, habitId, day])
  @@index([userId, day])
  @@index([habitId, day])
}

model Category {
  id         String    @id @default(cuid())
  userId     String?   // null for global categories, user id for user-owned
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  isArchived Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  expenses   Expense[]

  // Global categories are unique by name
  // User categories are unique per user by (userId, name)
  @@unique([userId, name])
  @@index([userId])
}